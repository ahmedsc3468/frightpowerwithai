DEFAULT_PHONE_REGION=PK

# --- Messaging email notifications (delayed unread) ---
# Turn this on to queue emails on new messages.
ENABLE_MESSAGE_EMAIL_NOTIFICATIONS=

# Delay (seconds) before sending the email, only if still unread.
MESSAGE_EMAIL_DELAY_SECONDS=

# SMTP (required to actually send emails)
# For Gmail you typically need an App Password (not your normal password).
SMTP_SERVER=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
# Used for links in the email template
FRONTEND_BASE_URL=http://localhost:5173

#for google calendar
CALENDAR_OAUTH_STATE_SECRET=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

